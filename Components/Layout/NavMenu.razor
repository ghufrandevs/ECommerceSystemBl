@using MudBlazor
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ECommerceSystemBl.Services

@implements IDisposable
@inject CartService CartService
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudAppBar Elevation="2"
           Class="main-navbar">

    <MudText Typo="Typo.h5"
             Class="ms-2 fw-bold">

        Commerce Shop

    </MudText>

    <MudSpacer />

    <MudButton Href="/"
               Variant="Variant.Text"
               Color="Color.Inherit">

        Home

    </MudButton>

    <MudButton Href="/products"
               Variant="Variant.Text"
               Color="Color.Inherit">

        Products

    </MudButton>

    @if (isAuthenticated && !isAdmin)
    {
        @if (cartCount > 0)
        {
            <MudBadge Content="@cartCount"
                      Color="Color.Error"
                      Overlap="true">

                <MudButton Href="/cart"
                           Variant="Variant.Text"
                           Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.ShoppingCart">

                    Cart

                </MudButton>

            </MudBadge>
        }
        else
        {
            <MudButton Href="/cart"
                       Variant="Variant.Text"
                       Color="Color.Inherit"
                       StartIcon="@Icons.Material.Filled.ShoppingCart">

                Cart

            </MudButton>
        }
    }

    @if (isAuthenticated && !isAdmin)
    {
        <MudButton Href="/my-orders"
                   Variant="Variant.Text"
                   Color="Color.Inherit">

            My Orders

        </MudButton>

        <MudButton Href="/profile"
                   Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Person">

            My Profile

        </MudButton>
    }

    @if (isAuthenticated && isAdmin)
    {
        <MudButton Href="/admin/dashboard"
                   Variant="Variant.Text"
                   Color="Color.Inherit">

            Dashboard

        </MudButton>
    }

    <MudSpacer />

    @if (!isAuthenticated)
    {
        <MudButton Href="/login"
                   Variant="Variant.Outlined"
                   Color="Color.Inherit">

            Login

        </MudButton>

        <MudButton Href="/register"
                   Variant="Variant.Outlined"
                   Color="Color.Inherit"
                   Class="ms-2">

            Register

        </MudButton>
    }

    @if (isAuthenticated)
    {
        <MudButton Href="/logout"
                   Variant="Variant.Text"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Logout">

            Logout

        </MudButton>
    }

</MudAppBar>

@code
{
    private bool isAuthenticated;

    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationStateProvider.AuthenticationStateChanged += AuthenticationStateChanged;
        CartService.OnCartChanged += CartChanged;

        await LoadUser();
    }

    private async Task LoadUser()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        isAuthenticated = user.Identity?.IsAuthenticated == true;

        isAdmin = user.IsInRole("Admin");
        if (isAuthenticated && !isAdmin)
        {
            int userId = int.Parse(
                user.FindFirst(ClaimTypes.NameIdentifier)!.Value);

            cartCount = CartService.GetCartCount(userId);
        }
        else
        {
            cartCount = 0;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async void AuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await LoadUser();
    }

    public void Dispose()
    {
        AuthenticationStateProvider.AuthenticationStateChanged -= AuthenticationStateChanged;
        CartService.OnCartChanged -= CartChanged;
    }

    private int cartCount;

    private async void CartChanged()
    {
        await LoadUser();
    }
}