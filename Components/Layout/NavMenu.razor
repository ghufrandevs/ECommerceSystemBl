@using MudBlazor

<MudAppBar Elevation="1" Color="Color.Surface">

    <MudText Typo="Typo.h5"
             Class="ms-2 fw-bold">

        Commerce Shop

    </MudText>

    <MudSpacer />

    <MudButton Href="/"
               Variant="Variant.Text"
               Color="Color.Default">

        Home

    </MudButton>

    <MudButton Href="/products"
               Variant="Variant.Text"
               Color="Color.Default">

        Products

    </MudButton>

    <MudButton Href="/categories"
               Variant="Variant.Text"
               Color="Color.Default">

        Categories

    </MudButton>

    <MudSpacer />

    <MudButton Href="/login"
               Variant="Variant.Outlined">

        Login

    </MudButton>

    <MudButton Href="/register"
               Variant="Variant.Filled"
               Color="Color.Primary"
               Class="ms-2">

        Register

    </MudButton>

</MudAppBar>