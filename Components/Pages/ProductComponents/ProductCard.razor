@using ECommerceSystemBl.DTOs
@inject NavigationManager Navigation

<MudCard Style="cursor:pointer;"
         Class="product-card"
         @onclick="OpenProduct">

    @if (!string.IsNullOrWhiteSpace(Product.ImageUrl))
    {
        <MudCardMedia Image="@Product.ImageUrl"
                      Height="240"
                      Class="product-image" />
    }
    else
    {
        <MudCardMedia Image="/images/products/default.jpg"
                      Height="240"
                      Class="product-image" />
    }

    <MudCardContent>

        <MudText Typo="Typo.h6"
                 Class="product-title">

            @Product.ProductName

        </MudText>

        <MudText Typo="Typo.body2"
                 Class="product-description">

            @Product.Description

        </MudText>

        <MudDivider Class="my-2" />

        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center">

            <MudText Class="price">

                OMR @Product.Price

            </MudText>

            <MudChip T="string"
                     Color="Color.Success"
                     Variant="Variant.Outlined">

                In Stock

            </MudChip>

        </MudStack>

        <MudText Class="rating mt-3">

            ⭐ @Product.OverallRating

        </MudText>

    </MudCardContent>

</MudCard>

@code
{
    [Parameter]
    public ProductOutputDTO Product { get; set; } = new();

    private void OpenProduct()
    {
        Navigation.NavigateTo($"/products/{Product.ProductId}");
    }
}