@using MudBlazor

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-10 mb-10">

    <MudGrid>

        <MudItem xs="12" md="6">

            <MudText Typo="Typo.h2" Class="mb-4">

                Electronics For Everyone

            </MudText>

            <MudText Typo="Typo.subtitle1"
                     Class="mb-6">

                Shop laptops, monitors, keyboards, headphones and accessories with modern technology and great prices.

            </MudText>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large">

                Shop Now

            </MudButton>

        </MudItem>

        <MudItem xs="12" md="6">

            <MudImage Src="Images/hero.png"
                      Fluid="true" />

        </MudItem>

    </MudGrid>

</MudContainer>