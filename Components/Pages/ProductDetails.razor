@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ECommerceSystemBl.Models
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ReviewService ReviewService
@page "/products/{id:int}"

@using ECommerceSystemBl.DTOs
@using ECommerceSystemBl.Services

@inject ProductService ProductService
@inject OrderService OrderService
@inject NavigationManager Navigation

@if (product == null)
{
    <MudAlert Severity="Severity.Error">
        Product Not Found
    </MudAlert>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">

        <MudPaper Elevation="4" Class="pa-6 rounded-lg">

            <MudText Typo="Typo.h4">
                @product.ProductName
            </MudText>

            <MudText Typo="Typo.body2"
                     Color="Color.Secondary"
                     Class="mb-4">

                @product.Description

            </MudText>

            <MudDivider Class="mb-4" />

            <MudText Class="mb-2">
                <b>Price:</b> OMR @product.Price
            </MudText>

            <MudText Class="mb-2">
                <b>Stock:</b> @product.Stock
            </MudText>

            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Spacing="1"
                      Class="mb-4">

                <MudText>
                    <b>Rating:</b>
                </MudText>

                <MudRating SelectedValue="@((int)Math.Round(product.OverallRating))"
                           ReadOnly="true"
                           MaxValue="5" />

                <MudChip T="string"
                         Color="Color.Warning"
                         Variant="Variant.Outlined"
                         Size="Size.Small">

                    @product.OverallRating.ToString("0.0")

                </MudChip>

            </MudStack>

            <MudStack Row="true"
                      Spacing="2">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           OnClick="BuyNow">

                    🛒 Buy Now

                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="Back">

                    Back

                </MudButton>

            </MudStack>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <MudAlert Severity="Severity.Success"
                          Class="mt-4">

                    @message

                </MudAlert>
            }
            <MudDivider Class="my-5" />

            <MudText Typo="Typo.h5" Class="mb-3">
                Customer Reviews
            </MudText>

            @if (reviews.Count == 0)
            {
                <MudAlert Severity="Severity.Info">
                    No reviews yet.
                </MudAlert>
            }


            else
            {
                @foreach (var review in reviews)
                {
                    <MudPaper Class="pa-3 mb-3" Elevation="1">

                        <MudText Typo="Typo.subtitle2">
                            <b>@review.UserName</b>
                        </MudText>

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Spacing="1">

                            <MudRating SelectedValue="@review.Rating"
                                       ReadOnly="true"
                                       MaxValue="5" />

                            <MudChip T="string"
                                     Color="Color.Warning"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">

                                @review.Rating

                            </MudChip>

                        </MudStack>

                        <MudText Typo="Typo.body1">
                            @review.Comment
                        </MudText>

                        <MudText Typo="Typo.caption"
                                 Color="Color.Secondary">

                            @review.ReviewDate.ToString("dd/MM/yyyy")

                        </MudText>

                    </MudPaper>
                }
            }
            <MudDivider Class="my-5" />

            <MudText Typo="Typo.h5" Class="mb-3">
                Write a Review
            </MudText>

            <MudNumericField T="int"
                             Label="Rating (1-5)"
                             @bind-Value="review.Rating"
                             Min="1"
                             Max="5"
                             Variant="Variant.Outlined"
                             Class="mb-3" />

            <MudTextField Label="Comment"
                          @bind-Value="review.Comment"
                          Lines="4"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="AddReview">

                Submit Review

            </MudButton>

            @if (!string.IsNullOrWhiteSpace(reviewMessage))
            {
                <MudAlert Severity="Severity.Info"
                          Class="mt-3">

                    @reviewMessage

                </MudAlert>
            }
        </MudPaper>

    </MudContainer>
}

@code
{
    [Parameter]
    public int id { get; set; }

    private ProductOutputDTO? product;

    private string message = "";

    protected override void OnParametersSet()
    {
        product = ProductService.GetProductById(id);
        reviews = ReviewService.GetProductReviews(id);
        review.ProductId = id;
    }

    private async Task BuyNow()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;


        if (user.Identity?.IsAuthenticated != true)
        {
            message = "Please login first.";
            return;
        }

        int userId = int.Parse(
            user.FindFirst(ClaimTypes.NameIdentifier)!.Value);

        

        PlaceOrderDTO dto = new()
        {
            Items = new List<ItemDTO>
        {
            new ItemDTO
            {
                ProductId = id,
                Quantity = 1
            }
        }
        };

        var result = OrderService.PlaceOrder(dto, userId);

        if (result is string messageResult)
        {
            message = messageResult;
        }
        else
        {
            Navigation.NavigateTo("/my-orders");
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/products");
    }

    private List<ReviewOutputDTO> reviews = new();
    private ReviewCreateDTO review = new();

    private string reviewMessage = "";

    private async Task AddReview()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            reviewMessage = "Please login first.";
            return;
        }

        int userId = int.Parse(
            user.FindFirst(ClaimTypes.NameIdentifier)!.Value);

        review.ProductId = id;

        reviewMessage = ReviewService.AddReview(review, userId);

        reviews = ReviewService.GetProductReviews(id);

        if (reviewMessage == "Review Added Successfully")
        {
            review = new ReviewCreateDTO
            {
                ProductId = id
            };
        }
    }
}