@page "/admin/dashboard"
@using ECommerceSystemBl.Helpers
@using Microsoft.AspNetCore.Components.Authorization

@using System.Security.Claims
@using ECommerceSystemBl.Services



@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ProductService ProductService
@inject CategoryService CategoryService
@inject UserService UserService
@inject OrderService OrderService
@if (authorized)
{

    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">

        <MudText Typo="Typo.h3">
            👋 Welcome Admin
        </MudText>

        <MudText Typo="Typo.body1"
        Color="Color.Secondary"
        Class="mb-6">

            Manage your e-commerce system from one place.

        </MudText>

        <MudGrid>

            <!-- Products -->

            <MudItem xs="12" md="3">

                <MudCard Elevation="4" Class="pa-4">

                    <MudCardContent>

                        <MudText Typo="Typo.h5">
                            📦 Products
                        </MudText>

                        <MudText Class="mt-2">
                            Total Products: <b>@productCount</b>
                        </MudText>

                    </MudCardContent>

                    <MudCardActions>

                        <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        OnClick="OpenProducts">

                            Open

                        </MudButton>

                    </MudCardActions>

                </MudCard>

            </MudItem>

            <!-- Categories -->

            <MudItem xs="12" md="3">

                <MudCard Elevation="4" Class="pa-4">

                    <MudCardContent>

                        <MudText Typo="Typo.h5">
                            📂 Categories
                        </MudText>

                        <MudText Class="mt-2">
                            Total Categories: <b>@categoryCount</b>
                        </MudText>

                    </MudCardContent>

                    <MudCardActions>

                        <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        OnClick="OpenCategories">

                            Open

                        </MudButton>

                    </MudCardActions>

                </MudCard>

            </MudItem>

            <!-- Users -->

            <MudItem xs="12" md="3">

                <MudCard Elevation="4" Class="pa-4">

                    <MudCardContent>

                        <MudText Typo="Typo.h5">
                            👥 Users
                        </MudText>

                        <MudText Class="mt-2">
                            Total Users: <b>@userCount</b>
                        </MudText>

                    </MudCardContent>

                    <MudCardActions>

                        <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        OnClick="OpenUsers">

                            Open

                        </MudButton>

                    </MudCardActions>

                </MudCard>

            </MudItem>

            <!-- Orders -->

            <MudItem xs="12" md="3">

                <MudCard Elevation="4" Class="pa-4">

                    <MudCardContent>

                        <MudText Typo="Typo.h5">
                            🛒 Orders
                        </MudText>

                        <MudText Class="mt-2">
                            Total Orders: <b>@orderCount</b>
                        </MudText>

                    </MudCardContent>

                    <MudCardActions>

                        <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        OnClick="OpenOrders">

                            Open

                        </MudButton>

                    </MudCardActions>

                </MudCard>

            </MudItem>

        </MudGrid>

    </MudContainer>
}
@code
{
    private int productCount;
    private int categoryCount;
    private int userCount;
    private int orderCount;

    protected override async Task OnInitializedAsync()
    {
        authorized = await AdminAuthorizationHelper.IsAdminAsync(
            AuthenticationStateProvider,
            Navigation);

        if (!authorized)
            return;

        productCount = ProductService.GetAllProducts().Count;
        categoryCount = CategoryService.GetAll().Count;
        userCount = UserService.GetAllUsers().Count;
        orderCount = OrderService.GetAllOrders().Count;
    }

    private void OpenProducts()
    {
        Navigation.NavigateTo("/admin/products");
    }

    private void OpenCategories()
    {
        Navigation.NavigateTo("/admin/categories");
    }

    private void OpenUsers()
    {
        Navigation.NavigateTo("/admin/users");
    }

    private void OpenOrders()
    {
        Navigation.NavigateTo("/admin/orders");
    }

    private bool authorized = false;
}